---
export interface GiftItem {
  id: string;
  name: string;
  description?: string | null;
  price_suggested?: number | null;
  currency: string;
}

export interface Props {
  gifts: GiftItem[];
}

const { gifts } = Astro.props;
---

<section class="mb-10">
  <h2 class="text-xl font-semibold mb-4">Regalos y donaciones</h2>

  {gifts.length === 0 ? (
    <p class="text-slate-500 text-sm">
      Todavía no hay regalos cargados.
    </p>
  ) : (
    <ul class="space-y-4">
      {gifts.map((gift) => (
        <li class="border border-slate-200 rounded-lg p-4 bg-white shadow-sm">
          <h3 class="font-semibold mb-1">{gift.name}</h3>

          {gift.description && (
            <p class="text-slate-600 text-sm mb-2">
              {gift.description}
            </p>
          )}

          {(gift.price_suggested !== null && gift.price_suggested !== undefined) && (
            <p class="text-sm font-medium text-emerald-700">
              Sugerido: {gift.price_suggested.toLocaleString('es-AR', {
                style: 'currency',
                currency: gift.currency,
              })}
            </p>
          )}

          <button
            class="mt-3 inline-flex items-center justify-center rounded-md border border-emerald-600 px-3 py-1.5 text-sm font-medium text-emerald-700 hover:bg-emerald-50 transition"
          >
            Aportar a este regalo
          </button>
        </li>
      ))}
    </ul>
  )}
</section>