---
// Sección de regalos
// TODO: Reemplazar con la URL real de Mercadopago
const MERCADOPAGO_URL = 'https://link.mercadopago.com.ar/bodacaroylauti';
---

<section id="regalos" class="py-14 md:py-24 px-6 bg-wedding-navy text-white text-center">
  <div class="max-w-2xl mx-auto">
    <div class="w-16 h-16 mx-auto mb-8">
      <lord-icon
        src="https://cdn.lordicon.com/etbpzgne.json"
        trigger="loop"
        delay="2000"
        colors="primary:#FDFFFA,secondary:#AAC5E5"
        style="width:64px;height:64px"
      ></lord-icon>
    </div>

    <p class="font-sans text-wedding-sky tracking-[0.3em] uppercase text-xs mb-3">Con todo nuestro cariño</p>
    <h2 class="font-serif text-3xl md:text-4xl lg:text-5xl font-light tracking-wide text-white mb-6">Regalos</h2>
    <div class="flex items-center gap-4 my-6 max-w-xs mx-auto">
      <div class="flex-1 h-px bg-wedding-sky/30"></div>
      <span class="text-wedding-sky text-xl">✦</span>
      <div class="flex-1 h-px bg-wedding-sky/30"></div>
    </div>

    <p class="font-serif text-lg md:text-xl italic font-light leading-relaxed text-white/80 mb-4">
      Tu presencia es el mejor regalo. Pero si viene con una transferencia o un sobrecito tampoco nos quejamos jeje <span class="not-italic">😜</span>
    </p>

    <p class="font-sans text-xs tracking-[0.25em] uppercase text-wedding-sky mb-4 animate-pulse mt-10">
      Click para hacer un regalo
    </p>

    <a
      href={MERCADOPAGO_URL}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center justify-center w-20 h-20 rounded-full bg-wedding-sky text-wedding-navy transition-all duration-300 hover:bg-white hover:text-wedding-navy hover:scale-105 mx-auto"
      aria-label="Hacernos un regalo"
    >
      <lord-icon
        src="https://cdn.lordicon.com/kezeezyg.json"
        trigger="loop"
        delay="1800"
        colors="primary:#0A2140,secondary:#FDFFFA"
        style="width:42px;height:42px"
      ></lord-icon>
    </a>

    <p class="mt-6 font-sans text-xs text-white/40 tracking-wide">
      Transferencia vía Mercado Pago · Link de pago seguro
    </p>

    <!-- Cards con datos bancarios -->
    <div class="mt-12 grid sm:grid-cols-2 gap-4 text-left">

      <!-- Lauti -->
      <div class="border border-wedding-sky/30 bg-white/5 p-6">
        <p class="font-sans text-xs tracking-[0.25em] uppercase text-wedding-sky mb-4">Datos de Lauti</p>
        <div class="space-y-3">
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">Nombre</p>
            <p class="font-sans text-sm text-white">Lautaro Benjamín Pavon</p>
          </div>
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">Alias</p>
            <p class="font-sans text-sm text-white font-medium">boda.caroylau</p>
          </div>
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">CVU</p>
            <p class="font-sans text-xs text-white/70 break-all">0000003100002211182429</p>
          </div>
        </div>
      </div>

      <!-- Caro -->
      <div class="border border-wedding-sky/30 bg-white/5 p-6">
        <p class="font-sans text-xs tracking-[0.25em] uppercase text-wedding-sky mb-4">Datos de Caro</p>
        <div class="space-y-3">
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">Nombre</p>
            <p class="font-sans text-sm text-white/50 italic">Próximamente</p>
          </div>
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">Alias</p>
            <p class="font-sans text-sm text-white/50 italic">Próximamente</p>
          </div>
          <div>
            <p class="font-sans text-xs text-white/40 uppercase tracking-wider mb-0.5">CVU</p>
            <p class="font-sans text-xs text-white/50 italic">Próximamente</p>
          </div>
        </div>
      </div>

    </div>
  </div>
</section>
