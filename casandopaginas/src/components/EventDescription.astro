---
export interface Props {
  description?: string;
}

const { description } = Astro.props;
---

{description && (
  <section class="mb-10">
    <h2 class="font-serif text-xl font-light mb-2 text-wedding-navy">Nuestra historia</h2>
    <p class="font-sans text-wedding-navy/70 leading-relaxed">
      {description}
    </p>
  </section>
)}