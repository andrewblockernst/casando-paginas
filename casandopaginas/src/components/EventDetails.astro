---
// Fecha, lugar y como llegar
// TODO: Reemplazar con la dirección real de la iglesia / salón
// TODO: Agregar hora real del casamiento civil
---

<section id="evento" class="py-24 px-6 bg-wedding-cream">
  <div class="max-w-5xl mx-auto">
    <!-- Título -->
    <div class="text-center mb-16">
      <p class="font-sans text-wedding-sky tracking-[0.3em] uppercase text-xs mb-3">El gran día</p>
      <h2 class="section-title">Fecha & Lugar</h2>
      <div class="divider-ornament max-w-xs mx-auto">
        <span class="text-wedding-sage text-xl">✦</span>
      </div>
    </div>

    <!-- Grilla de eventos -->
    <div class="grid md:grid-cols-2 gap-8 mb-16">

      <!-- Casamiento Civil -->
      <div class="border border-wedding-sage/50 p-8 text-center hover:shadow-lg transition-shadow duration-300 bg-white">
        <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center">
          <lord-icon
            src="https://cdn.lordicon.com/fikcyfpp.json"
            trigger="hover"
            colors="primary:#0A2140,secondary:#AAC5E5"
            style="width:48px;height:48px"
          ></lord-icon>
        </div>
        <p class="font-sans text-xs tracking-[0.3em] uppercase text-wedding-sky mb-2">Civil</p>
        <h3 class="font-serif text-2xl text-wedding-navy font-light mb-4">Casamiento Civil</h3>
        <p class="font-sans text-wedding-navy/70 text-sm leading-relaxed mb-1">
          Fecha y hora a confirmar
        </p>
        <p class="font-sans text-wedding-navy/50 text-xs tracking-wide">
          Registro Civil · San Martin 420, E3103 Puiggari, Entre Ríos
        </p>
      </div>

      <!-- Ceremonia Religiosa -->
      <div class="border border-wedding-sage/50 p-8 text-center hover:shadow-lg transition-shadow duration-300 bg-white">
        <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center">
          <lord-icon
            src="https://cdn.lordicon.com/fshosubk.json"
            trigger="hover"
            colors="primary:#0A2140,secondary:#AAC5E5"
            style="width:48px;height:48px"
          ></lord-icon>
        </div>
        <p class="font-sans text-xs tracking-[0.3em] uppercase text-wedding-sky mb-2">Iglesia</p>
        <h3 class="font-serif text-2xl text-wedding-navy font-light mb-4">Ceremonia Religiosa</h3>
        <p class="font-sans text-wedding-navy/70 text-sm mb-1">Lunes 12 de octubre de 2026</p>
        <p class="font-sans text-wedding-navy/70 text-sm mb-3">
          <!-- TODO: Agregar hora real -->
          Hora a confirmar
        </p>
        <p class="font-sans text-wedding-navy/50 text-xs tracking-wide">
        Country Golf Club          
        </p>
      </div>

      <!-- Recepción / Fiesta -->
      <div class="border border-wedding-sage/50 p-8 text-center hover:shadow-lg transition-shadow duration-300 bg-white md:col-span-2 md:max-w-md md:mx-auto w-full">
        <div class="w-12 h-12 mx-auto mb-5 flex items-center justify-center">
          <lord-icon
            src="https://cdn.lordicon.com/lupuorrc.json"
            trigger="hover"
            colors="primary:#0A2140,secondary:#AAC5E5"
            style="width:48px;height:48px"
          ></lord-icon>
        </div>
        <p class="font-sans text-xs tracking-[0.3em] uppercase text-wedding-sky mb-2">Festejo</p>
        <h3 class="font-serif text-2xl text-wedding-navy font-light mb-4">Recepción & Fiesta</h3>
        <p class="font-sans text-wedding-navy/70 text-sm mb-1">Lunes 12 de octubre de 2026</p>
        <p class="font-sans text-wedding-navy/70 text-sm mb-3">
          <!-- TODO: Agregar hora del ingreso a la fiesta -->
          Hora a confirmar
        </p>
        <p class="font-sans text-wedding-navy/50 text-xs tracking-wide mb-6">
          <!-- TODO: Agregar nombre y dirección del salón -->
          Salón · Country Golf
        </p>
        <!-- Botón Cómo llegar -->
        <a
          href="https://maps.app.goo.gl/srmc2QxFJXcCpNL38"
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary text-xs"
          aria-label="Cómo llegar al Country Golf Club (abre en nueva ventana)"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" aria-hidden="true" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
            <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
          </svg>
          Cómo llegar
        </a>
      </div>
    </div>

    <!-- Embed de Google Maps -->
    <div class="w-full overflow-hidden border border-wedding-sage/30 shadow-sm">
      <iframe
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d1777.8141096652657!2d-60.45801697130162!3d-32.06112390282152!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x95b42e24d286b54d%3A0xfd014fb3bcc0785e!2sCountry%20Golf%20Club!5e1!3m2!1ses-419!2sar!4v1771827467997!5m2!1ses-419!2sar"
        width="100%"
        height="400"
        style="border:0;"
        allowfullscreen
        loading="lazy"
        referrerpolicy="no-referrer-when-downgrade"
        title="Mapa de ubicación del Country Golf Club"
      ></iframe>
    </div>

    <!-- Alojamientos -->
    <div class="mt-16">
      <div class="text-center mb-10">
        <p class="font-sans text-wedding-sky tracking-[0.3em] uppercase text-xs mb-3">Para que descanses bien</p>
        <h3 class="font-serif text-3xl text-wedding-navy font-light mb-4">Dónde quedarse</h3>
        <div class="divider-ornament max-w-xs mx-auto">
          <span class="text-wedding-sage text-xl">✦</span>
        </div>
      </div>

      <div class="grid md:grid-cols-3 gap-6">

        <!-- Hoteles -->
        <div class="border border-wedding-sage/40 bg-white p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-full bg-wedding-sky/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-wedding-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
              </svg>
            </div>
            <h4 class="font-serif text-lg text-wedding-navy font-light">Hoteles</h4>
          </div>
          <ul class="space-y-4">
            <li class="border-b border-wedding-sage/20 pb-4">
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel MEORANS</p>
              <a href="tel:03434166511" class="font-sans text-xs text-wedding-sky hover:underline">03434 166511</a>
            </li>
            <li class="border-b border-wedding-sage/20 pb-4">
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel La Colina</p>
              <a href="tel:03434910029" class="font-sans text-xs text-wedding-sky hover:underline">03434 910029</a>
            </li>
            <li>
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel Jalisco</p>
              <a href="tel:03434911226" class="font-sans text-xs text-wedding-sky hover:underline">03434 911226</a>
            </li>
          </ul>
        </div>

        <!-- Alquiler por día -->
        <div class="border border-wedding-sage/40 bg-white p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-full bg-wedding-sky/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-wedding-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
              </svg>
            </div>
            <h4 class="font-serif text-lg text-wedding-navy font-light">Alquiler por día</h4>
          </div>
          <p class="font-sans text-xs text-wedding-navy/50 mb-4 leading-relaxed">Disponibles en Google Maps, Booking y otras plataformas de alquiler.</p>
          <ul class="space-y-2">
            <li class="font-sans text-sm text-wedding-navy">Los Álamos</li>
            <li class="font-sans text-sm text-wedding-navy">Hospedaje los Lapachos</li>
            <li class="font-sans text-sm text-wedding-navy">BELGRANO 85 <span class="text-xs text-wedding-navy/40">· 1 dormitorio</span></li>
            <li class="font-sans text-sm text-wedding-navy">Las Agujas <span class="text-xs text-wedding-navy/40">· 1 dormitorio</span></li>
            <li class="font-sans text-sm text-wedding-navy">Lust 270 <span class="text-xs text-wedding-navy/40">· 1 dormitorio</span></li>
            <li class="font-sans text-sm text-wedding-navy">Duplex Houssay <span class="text-xs text-wedding-navy/40">· 2 dormitorios</span></li>
          </ul>
        </div>

        <!-- Ciudades vecinas -->
        <div class="border border-wedding-sage/40 bg-white p-6">
          <div class="flex items-center gap-3 mb-5">
            <div class="w-8 h-8 rounded-full bg-wedding-sky/10 flex items-center justify-center shrink-0">
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-wedding-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </div>
            <h4 class="font-serif text-lg text-wedding-navy font-light">Ciudades vecinas</h4>
          </div>
          <p class="font-sans text-xs text-wedding-navy/50 mb-4">Crespo</p>
          <ul class="space-y-4">
            <li class="border-b border-wedding-sage/20 pb-4">
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel Garten</p>
              <a href="tel:03434954594" class="font-sans text-xs text-wedding-sky hover:underline">03434 954594</a>
            </li>
            <li class="border-b border-wedding-sage/20 pb-4">
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel Crespo</p>
              <a href="tel:03435044872" class="font-sans text-xs text-wedding-sky hover:underline">03435 044872</a>
            </li>
            <li>
              <p class="font-sans text-sm font-medium text-wedding-navy">Hotel el Águila</p>
              <a href="tel:03434952060" class="font-sans text-xs text-wedding-sky hover:underline">03434 952060</a>
            </li>
          </ul>
        </div>

      </div>
    </div>

  </div>
</section>
