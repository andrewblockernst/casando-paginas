---
// Hero con carrusel de fotos
const slides = [
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.37.jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.37%20(1).jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.37%20(2).jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.37%20(3).jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.37%20(4).jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.38.jpeg', alt: 'Caro y Lauti' },
  { src: '/images/WhatsApp%20Image%202026-02-22%20at%2018.22.38%20(1).jpeg', alt: 'Caro y Lauti' },
];
---

<section id="inicio" class="relative w-full h-screen min-h-[600px] overflow-hidden">
  <!-- Carrusel de fondo -->
  <div id="carousel" class="relative w-full h-full">
    {slides.map((slide, i) => (
      <div
        class="carousel-slide absolute inset-0 w-full h-full transition-opacity duration-1000"
        data-index={i}
        style={`opacity: ${i === 0 ? 1 : 0};`}
      >
        <img
          src={slide.src}
          alt={slide.alt}
          class="w-full h-full object-cover object-[center_25%]"
          loading={i === 0 ? 'eager' : 'lazy'}
          decoding="async"
        />
      </div>
    ))}

    <!-- Overlay oscuro para legibilidad (Mejorado con gradiente para la zona superior) -->
    <div class="absolute inset-0 bg-gradient-to-b from-wedding-navy/80 via-wedding-navy/30 to-wedding-navy/10 z-10"></div>

    <!-- Contenido del hero desplazado hacia la parte superior media -->
    <div class="absolute inset-0 z-20 flex flex-col items-center justify-start text-center px-6 pt-32 md:pt-40 lg:pt-28 mb-10">
      <!-- Logo -->
      <img
        src="/images/logo-casamiento-white.png"
        alt="Caro & Lauti"
        class="w-32 sm:w-48 md:w-56 lg:w-60 mb-4 md:mb-6 lg:mb-3 drop-shadow-lg animate-fade-in"
      />

      <!-- Nombres -->
      <h1 class="font-serif text-4xl sm:text-5xl md:text-7xl lg:text-8xl text-white font-light tracking-widest mb-4 drop-shadow-lg">
        Caro <span class="text-wedding-sky">&</span> Lauti
      </h1>

      <!-- Fecha -->
      <p class="font-sans text-white/90 tracking-[0.4em] uppercase text-sm md:text-base mb-8">
        12 · 10 · 2026
      </p>
    </div>

    <!-- Dots de navegación -->
    <div class="absolute bottom-8 left-1/2 -translate-x-1/2 z-30 flex gap-3" id="carousel-dots">
      {slides.map((_, i) => (
        <button
          class="carousel-dot w-2 h-2 rounded-full transition-all duration-300"
          data-dot={i}
          style={i === 0 ? 'background-color: #FDFFFA; transform: scale(1.3);' : 'background-color: rgba(253,255,250,0.4);'}
          aria-label={`Ir a foto ${i + 1}`}
        />
      ))}
    </div>
  </div>
</section>

<script>
  const slides = document.querySelectorAll('.carousel-slide');
  const dots = document.querySelectorAll('.carousel-dot');
  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    slides[current].style.opacity = '0';
    dots[current].style.backgroundColor = 'rgba(253,255,250,0.4)';
    dots[current].style.transform = 'scale(1)';
    current = index;
    slides[current].style.opacity = '1';
    dots[current].style.backgroundColor = '#FDFFFA';
    dots[current].style.transform = 'scale(1.3)';
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function startAutoplay() {
    timer = setInterval(next, 5000);
  }

  dots.forEach((dot) => {
    dot.addEventListener('click', () => {
      clearInterval(timer);
      goTo(parseInt((dot as HTMLElement).dataset.dot || '0'));
      startAutoplay();
    });
  });

  startAutoplay();
</script>
