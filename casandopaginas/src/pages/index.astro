---
import '../styles/global.css';
import Hero from '../components/Hero.astro';
import Countdown from '../components/Countdown.astro';
import EventDetails from '../components/EventDetails.astro';
import RSVP from '../components/RSVP.astro';
import DressCode from '../components/DressCode.astro';
import Gifts from '../components/Gifts.astro';
import Songs from '../components/Songs.astro';
import FAQ from '../components/FAQ.astro';
import Farewell from '../components/Farewell.astro';
import Footer from '../components/Footer.astro';
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#FDFFFA" />
    <meta name="theme-color" media="(prefers-color-scheme: dark)" content="#FDFFFA" />
    <meta name="description" content="Caro & Lauti - 12 de octubre de 2026. Sitio oficial del casamiento." />
    <link rel="icon" type="image/png" href="/images/logo-casamiento.png" />
    <title>Caro & Lauti · 12.10.2026</title>

    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Open Graph -->
    <meta property="og:title" content="Caro & Lauti · 12.10.2026" />
    <meta property="og:description" content="¡Nos casamos! Te invitamos a celebrar con nosotros el 12 de octubre de 2026." />
    <meta property="og:image" content="/images/logo-casamiento.png" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_AR" />
    <meta property="og:site_name" content="Caro & Lauti · Casamiento 2026" />
    <!-- Twitter Cards -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Caro & Lauti · 12.10.2026" />
    <meta name="twitter:description" content="¡Nos casamos! Te invitamos a celebrar con nosotros el 12 de octubre de 2026." />
    <meta name="twitter:image" content="/images/logo-casamiento.png" />

    <!-- Lordicon web component -->
    <script src="https://cdn.lordicon.com/lordicon.js"></script>
  </head>

  <body class="bg-wedding-cream text-wedding-navy overflow-x-hidden">

    <!-- Navegación sticky -->
    <nav id="main-nav" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300 py-4 px-6">
      <div class="max-w-6xl mx-auto flex items-center justify-between">
        <!-- Logo pequeño en nav -->
        <a href="#inicio" class="shrink-0">
          <img
            src="/images/logo-casamiento-white.png"
            alt="Caro & Lauti"
            class="h-8 md:h-10 object-contain opacity-0 transition-opacity duration-300"
            id="nav-logo"
          />
        </a>

        <!-- Links de navegación - desktop -->
        <div class="hidden md:flex items-center gap-8">
          {[
            { href: '#evento', label: 'El Día' },
            { href: '#alojamientos', label: 'Alojamiento' },
            { href: '#asistencia', label: 'Asistencia' },
            { href: '#vestimenta', label: 'Vestimenta' },
            { href: '#regalos', label: 'Regalos' },
            { href: '#canciones', label: 'Canciones' },
            { href: '#fotos', label: 'Fotos' },
            { href: '#preguntas', label: 'FAQ' },
          ].map(link => (
            <a
              href={link.href}
              class="nav-link font-sans text-xs tracking-[0.2em] uppercase transition-colors duration-200"
              style="color: transparent;"
            >
              {link.label}
            </a>
          ))}
        </div>

        <!-- Botón hamburguesa - mobile -->
        <button
          id="mobile-menu-btn"
          class="md:hidden p-2"
          aria-label="Menú"
          style="color: transparent;"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
        </button>
      </div>

      <!-- Menú mobile desplegable -->
      <div id="mobile-menu" class="hidden md:hidden mt-2 pb-4 border-t border-white/20">
        <div class="max-w-6xl mx-auto flex flex-col gap-3 pt-4 px-2">
          {[
            { href: '#evento', label: 'El Día' },
            { href: '#alojamientos', label: 'Alojamiento' },
            { href: '#asistencia', label: 'Asistencia' },
            { href: '#vestimenta', label: 'Vestimenta' },
            { href: '#regalos', label: 'Regalos' },
            { href: '#canciones', label: 'Canciones' },
            { href: '#fotos', label: 'Fotos' },
            { href: '#preguntas', label: 'FAQ' },
          ].map(link => (
            <a
              href={link.href}
              class="font-sans text-xs tracking-[0.2em] uppercase text-white py-1"
            >
              {link.label}
            </a>
          ))}
        </div>
      </div>
    </nav>

    <!-- Secciones principales -->
    <Hero />
    <Countdown />
    <EventDetails />

    <RSVP />
    <DressCode />
    <Gifts />
    <Songs />

    <!-- Fotos -->
    <section id="fotos" class="py-12 md:py-16 px-6 bg-wedding-cream">
      <div class="max-w-3xl mx-auto text-center">
        <div class="w-16 h-16 mx-auto">
          <lord-icon
            src="https://cdn.lordicon.com/wsaaegar.json"
            trigger="loop"
            delay="2000"
            colors="primary:#0A2140,secondary:#AAC5E5"
            style="width:64px;height:64px"
          ></lord-icon>
        </div>
        <p class="font-sans text-wedding-sky tracking-[0.3em] uppercase text-xs mb-3">Los mejores momentos</p>
        <h2 class="font-serif text-3xl md:text-4xl font-light tracking-wide text-wedding-navy mb-4">Fotos</h2>
        <div class="flex items-center gap-4 my-6 max-w-xs mx-auto">
          <div class="flex-1 h-px bg-wedding-sage/30"></div>
          <span class="text-wedding-sage text-xl">✦</span>
          <div class="flex-1 h-px bg-wedding-sage/30"></div>
        </div>

        <h3 class="font-serif text-xl font-light text-wedding-navy mb-2">Compartí tus fotos</h3>
        <p class="font-sans text-sm text-wedding-navy/70 mb-8 max-w-sm mx-auto">
          Ayudanos a guardar los mejores recuerdos de este día inolvidable subiendo tus fotos y videos.
        </p>

        <!-- Dos botones de subida -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

          <!-- Civil -->
          <div class="photos-card group border border-wedding-sage/30 bg-white shadow-sm p-7 flex flex-col items-center text-center transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="photos-icon-wrap mb-4 w-14 h-14 rounded-full flex items-center justify-center bg-wedding-sky/10 group-hover:bg-wedding-sky/20 transition-colors duration-300">
              <!-- Documento firmándose -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-wedding-sky" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M16.862 4.487 18.3 3.05a1.125 1.125 0 0 1 1.591 1.591l-1.5 1.5" />
              </svg>
            </div>
            <h4 class="font-serif text-lg font-light text-wedding-navy mb-2">Civil</h4>
            <p class="font-sans text-xs text-wedding-navy/60 mb-5 leading-relaxed">
              Subí las fotos y videos de la ceremonia civil aquí.
            </p>
            <a
              id="btn-fotos-civil"
              href="https://drive.google.com/drive/folders/1tqta9itB8ajawn8IlyGjA8sjA9dwDex2"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-sans text-xs tracking-wider uppercase bg-wedding-navy text-white px-6 py-3 hover:bg-wedding-sky transition-colors duration-300 w-full justify-center"
            >
              Subir fotos civil
            </a>
          </div>

          <!-- Ceremonia & Fiesta -->
          <div class="photos-card group border border-wedding-sage/30 bg-white shadow-sm p-7 flex flex-col items-center text-center transition-all duration-300 hover:shadow-md hover:-translate-y-0.5">
            <div class="photos-icon-wrap mb-4 w-14 h-14 rounded-full flex items-center justify-center bg-wedding-sage/15 group-hover:bg-wedding-sage/25 transition-colors duration-300">
              <!-- Copa brindando / festejando -->
              <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-wedding-sage" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.813 15.904 9 18.75l-.813-2.846a4.5 4.5 0 0 0-3.09-3.09L2.25 12l2.846-.813a4.5 4.5 0 0 0 3.09-3.09L9 5.25l.813 2.846a4.5 4.5 0 0 0 3.09 3.09L15.75 12l-2.846.813a4.5 4.5 0 0 0-3.09 3.09ZM18.259 8.715 18 9.75l-.259-1.035a3.375 3.375 0 0 0-2.455-2.456L14.25 6l1.036-.259a3.375 3.375 0 0 0 2.455-2.456L18 2.25l.259 1.035a3.375 3.375 0 0 0 2.456 2.456L21.75 6l-1.035.259a3.375 3.375 0 0 0-2.456 2.456ZM16.894 20.567 16.5 21.75l-.394-1.183a2.25 2.25 0 0 0-1.423-1.423L13.5 18.75l1.183-.394a2.25 2.25 0 0 0 1.423-1.423l.394-1.183.394 1.183a2.25 2.25 0 0 0 1.423 1.423l1.183.394-1.183.394a2.25 2.25 0 0 0-1.423 1.423Z" />
              </svg>
            </div>
            <h4 class="font-serif text-lg font-light text-wedding-navy mb-2">Ceremonia & Fiesta</h4>
            <p class="font-sans text-xs text-wedding-navy/60 mb-5 leading-relaxed">
              Subí las fotos y videos de la ceremonia y la fiesta aquí.
            </p>
            <a
              id="btn-fotos-fiesta"
              href="https://drive.google.com/drive/folders/1zXdXaLx5lU5NBQaZvzN09lv_RHasKByW"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 font-sans text-xs tracking-wider uppercase bg-wedding-sage text-white px-6 py-3 hover:bg-wedding-sage/80 transition-colors duration-300 w-full justify-center"
            >

              Subir fotos ceremonia & fiesta
            </a>
          </div>

        </div>
      </div>
    </section>

    <FAQ />
    <Farewell />
    <Footer />

  </body>
</html>

<script>
  const nav = document.getElementById('main-nav')!;
  const navLogo = document.getElementById('nav-logo')!;
  const navLinks = document.querySelectorAll('.nav-link') as NodeListOf<HTMLElement>;
  const mobileMenuBtn = document.getElementById('mobile-menu-btn')!;
  const mobileMenu = document.getElementById('mobile-menu')!;

  function onScroll() {
    const scrolled = window.scrollY > 80;

    if (scrolled) {
      nav.classList.add('bg-wedding-navy/95', 'backdrop-blur-sm', 'shadow-lg', 'py-2');
      nav.classList.remove('py-4');
      navLogo.style.opacity = '1';
      navLinks.forEach(l => { l.style.color = 'rgba(253,255,250,0.75)'; });
      (mobileMenuBtn as HTMLElement).style.color = 'rgba(253,255,250,0.9)';
    } else {
      nav.classList.remove('bg-wedding-navy/95', 'backdrop-blur-sm', 'shadow-lg', 'py-2');
      nav.classList.add('py-4');
      navLogo.style.opacity = '0';
      navLinks.forEach(l => { l.style.color = 'transparent'; });
      (mobileMenuBtn as HTMLElement).style.color = 'transparent';
    }
  }

  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  mobileMenuBtn.addEventListener('click', () => {
    mobileMenu.classList.toggle('hidden');
  });

  mobileMenu.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => mobileMenu.classList.add('hidden'));
  });
</script>

