---
import EventLayout from '../layouts/EventLayout.astro';
import EventHero from '../components/EventHero.astro';
import EventDescription from '../components/EventDescription.astro';
import GiftCatalog from '../components/GiftCatalog.astro';

import { supabase } from '../lib/supabaseClient';

export const prerender = true;

export async function getStaticPaths() {
  const targetSlug = 'caro-y-lauti-2026';

  const { data: event } = await supabase
    .from('events')
    .select('*')
    .eq('slug', targetSlug)
    .single();

  if (!event) {
    return [];
  }

  const { data: giftItems } = await supabase
    .from('gift_items')
    .select('*')
    .eq('event_id', event.id)
    .eq('is_active', true)
    .order('sort_order', { ascending: true })
    .order('created_at', { ascending: true });

  return [
    {
      params: { slug: targetSlug },
      props: {
        event,
        gifts: giftItems ?? [],
      },
    },
  ];
}

const { event, gifts } = Astro.props;
---

<EventLayout title={event ? event.title : "Evento no encontrado"}>
  {event ? (
    <>
      <EventHero {...event} />
      <EventDescription description={event.description} />
      <GiftCatalog gifts={gifts} />
    </>
  ) : (
    <section class="text-center py-20">
      <h1 class="text-2xl font-bold">Evento no encontrado</h1>
      <p class="text-slate-600 mt-2">
        Revisá el link, quizás fue dado de baja.
      </p>
    </section>
  )}
</EventLayout>